@using Microsoft.AspNetCore.Components.Authorization
@using TransporteWeb.Components.Layout
@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager NavigationManager

<CascadingAuthenticationState>
    <!-- ✅ Envolver todo con esto -->
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    <!-- ✅ Mostrar mensaje y link, NO redirigir automáticamente -->
                    <LayoutView Layout="@typeof(LoginLayout)">
                        <div class="text-center mt-5">
                            <h3>Acceso no autorizado</h3>
                            <p>Por favor, <a href="/auth/login">inicia sesión</a> para continuar.</p>
                        </div>
                    </LayoutView>
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>No encontrado</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <p role="alert">Lo sentimos, esta dirección no existe.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>