@using System.Text.RegularExpressions
@using System.ComponentModel.DataAnnotations
@using Domain.Dto
@using Microsoft.AspNetCore.Authorization
@using TransporteWeb.Repository.Interfaz
@inject ISnackbar Snackbar
@inject IBaseRepository<Rol,RolDto> RolService
@attribute [Authorize]
@page "/rol"

<h3>RolPage</h3>

<MudPaper Height="90%" Width="90%" Class="mx-auto">
    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-6" @ref="_tabs">

        <MudTabPanel Text="Lista">

            <MudDataGrid T="RolDto" Items="@roles" SortMode="SortMode.Multiple" Filterable="true"
                         Hideable="true">
                    
                <Columns>
                    <PropertyColumn Property="x => x.Nombre" Title="Nombre" />
                    <PropertyColumn Property="x => x.Descripcion" />

                    <TemplateColumn CellClass="d-flex justify-end">
                        <CellTemplate>
                            @{
                                var item = context.Item;  // context es el item actual de la tabla
                            }
                            <MudStack Row>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                               OnClick="() => GetItemById(item.Id)" Class="mx-1" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                               OnClick="() => DeleteItem(item.Id)" Class="mx-1" />
                            </MudStack>
                        </CellTemplate>
                    </TemplateColumn>

                </Columns>
                <PagerContent>
                    <MudDataGridPager T="RolDto" />
                </PagerContent>
            </MudDataGrid>
        </MudTabPanel>


        <MudTabPanel Text="Formulario">

            <MudGrid>
                <MudItem xs="12" sm="7" md="10">
                      
                    <MudForm @ref="_form" @bind-IsValid="@_success" @bind-Errors="@_errors" OnEnterPressed="@(() => _form.ValidateAsync())">
                                
                        <MudTextField T="string" @bind-Value="rol.Nombre" Label="Nombre" Required="true" RequiredError="Nombre es requerido!" />
                        <MudTextField T="string" @bind-Value="rol.Descripcion" Label="Descripcion" Required="true" RequiredError="Descripcion es requerido!" />
              

                        <MudItem sm="12" md="6">
                            <MudCheckBox @bind-Value="Crear" Label="Crear"></MudCheckBox>
                            <MudCheckBox @bind-Value="Editar" Label="Editar"></MudCheckBox>
                            <MudCheckBox @bind-Value="Leer" Label="Leer"></MudCheckBox>
                            <MudCheckBox @bind-Value="Eliminar" Label="Eliminar"></MudCheckBox>
                                    
                        </MudItem>
                              
                    </MudForm>

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto" OnClick="@(async () => await Submit())">Order</MudButton>
                           
       
                </MudItem>
  
            </MudGrid>

        </MudTabPanel>
    </MudTabs>
        
</MudPaper>

